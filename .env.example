# Required: dashboard access token for the Vercel auth gate.
# Use a random 32+ character value. Do not use brand/year words.
DASHBOARD_TOKEN=replace_with_random_32_plus_character_token

# Recommended: HMAC signing key for the auth session cookie.
# Use another random 32+ character value. If omitted, DASHBOARD_TOKEN is used.
SESSION_SECRET=replace_with_random_32_plus_character_session_secret

# Optional: cookie key. Rotate this if the cookie format is changed.
COOKIE_KEY=weather_ops_auth

# Required for live data: Apps Script web app URL that returns Weather Ops dashboard JSON.
# Example: https://script.google.com/macros/s/AKfycb.../exec
WEATHER_OPS_API_URL=

# Optional: shared token passed to Apps Script as ?token=...
WEATHER_OPS_API_TOKEN=

# Development only. Keep true until Apps Script dashboard API is deployed.
# In production, set WEATHER_OPS_ALLOW_SAMPLE=false after live API is connected.
WEATHER_OPS_ALLOW_SAMPLE=true
